# ── WB Shturval frontend — environment variables ─────────────────────────────
# Copy to `.env` (or `.env.local`). Vite only exposes vars prefixed with VITE_.

# Base URL of the backend API.
# Local dev: leave EMPTY — Vite proxies /api to the backend (see vite.config.ts).
# Production: set to your deployed backend origin, e.g. https://api.your-domain.ru
VITE_API_URL=""

# Optional: override the backend the dev proxy points to (default http://localhost:4000).
VITE_DEV_BACKEND="http://localhost:4000"
