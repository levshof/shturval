# ── WB Shturval backend — environment variables ──────────────────────────────
# Copy this file to `.env` and fill the values. NEVER commit the real .env.
# See SETUP_GUIDE.md for where to get each value.

# PostgreSQL connection string.
# Local (docker compose): postgresql://wb:wb@localhost:5432/wb_shturval?schema=public
# Managed (Supabase/Neon/Railway): use the connection string they give you.
DATABASE_URL="postgresql://wb:wb@localhost:5432/wb_shturval?schema=public"

# HTTP port the backend listens on.
PORT="4000"

# Comma-separated list of allowed frontend origins (CORS).
# Local dev default below; add your deployed frontend URL in production.
CORS_ORIGIN="http://localhost:5173"

# Secret used to sign session JWTs. Use a long random string (>= 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string"

# How long a login session stays valid.
JWT_EXPIRES_IN="7d"

# 32-byte key (base64) used to encrypt the stored WB API key (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: if you lose this, stored WB keys cannot be decrypted (re-enter them).
ENCRYPTION_KEY="change-me-32-byte-base64-key"

# Set to "true" when serving over HTTPS in production (marks the auth cookie Secure).
COOKIE_SECURE="false"

# Cookie SameSite policy.
#   lax  — same-origin setups (local, Docker, or Vercel /api proxy → Render). Default.
#   none — cross-site frontend↔backend (e.g. Vercel calling Render directly).
#          Requires HTTPS; Secure is forced on automatically.
COOKIE_SAMESITE="lax"

# Node environment.
NODE_ENV="development"

# ── Wildberries sync tuning (safe defaults; change only if you understand them) ─
# Minimum delay between calls to the same WB statistics endpoint (ms). WB limit
# is ~1 request/minute, so keep >= 60000 in production.
WB_MIN_INTERVAL_MS="60000"
# Hard cap on pages per single WB export (anti-infinite-loop safety).
WB_MAX_PAGES="200"
# How many days of orders/sales history to pull on first sync (WB stores ~90).
WB_HISTORY_DAYS="90"
