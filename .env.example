# ── WB Shturval — docker-compose secrets ─────────────────────────────────────
# Copy to `.env` (same folder as docker-compose.yml) and fill the values.
# docker compose reads this file automatically. NEVER commit the real .env.

# Database (used by the db service and assembled into DATABASE_URL for backend).
POSTGRES_USER=wb
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=wb_shturval

# Origin of the web app (the browser URL). For local compose this is the web port.
CORS_ORIGIN=http://localhost:8080

# Secret to sign session JWTs (>= 32 random chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-long-random-string

# 32-byte base64 key to encrypt the stored WB API key (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change-me-32-byte-base64-key

# Set to "true" only when serving the app over HTTPS (marks the auth cookie Secure).
COOKIE_SECURE=false
